{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": { "enabled": false },
  "organizeImports": { "enabled": true },
  "files": {
    "ignore": ["dist", "src/generated", "spec", "build", "coverage", "docs-api", "node_modules"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "overrides": [
    {
      "include": ["test/**", "examples/**", "scripts/**"],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off" },
          "performance": { "noDelete": "off" }
        }
      }
    }
  ]
}
