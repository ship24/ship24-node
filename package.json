{
  "name": "ship24",
  "version": "1.0.0",
  "description": "Official Node.js & TypeScript SDK for the Ship24 Tracking API",
  "type": "module",
  "license": "MIT",
  "author": "Ship24",
  "homepage": "https://github.com/ship24/ship24-node#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ship24/ship24-node.git"
  },
  "bugs": {
    "url": "https://github.com/ship24/ship24-node/issues"
  },
  "keywords": [
    "ship24",
    "tracking",
    "package-tracking",
    "parcel-tracking",
    "shipment-tracking",
    "courier",
    "logistics",
    "shipping",
    "tracking-api",
    "sdk",
    "typescript",
    "esm"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": ["dist", "LICENSE", "README.md"],
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate": "tsx scripts/generate-types.ts",
    "check:exports": "publint --strict && attw --pack .",
    "docs": "typedoc",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.0",
    "@types/node": "^22.10.0",
    "openapi-typescript": "^7.4.0",
    "publint": "^0.2.12",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typedoc": "^0.27.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6",
    "yaml": "^2.6.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
